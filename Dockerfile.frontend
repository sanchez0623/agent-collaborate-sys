# ============================================================
# MultiAgentSystem - 前端容器
# React + Vite dev server，热更新
# ============================================================

FROM node:22-alpine

WORKDIR /app

# 依赖安装（利用 Docker 层缓存）
COPY frontend/package.json frontend/package-lock.json ./
RUN npm install

# 源码
COPY frontend/ .

EXPOSE 5173
CMD ["npx", "vite", "--host", "0.0.0.0"]
